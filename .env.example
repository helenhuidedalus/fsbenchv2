# .env.example — copy to .env and fill in values for local runs.
# CI reads these from GitHub Actions encrypted secrets; .env is for local use only.
# Never commit .env.

DAYTONA_API_KEY=
E2B_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
TENSORLAKE_API_KEY=

# Optional overrides
# BENCH_N=10
# BENCH_REPO=https://github.com/dedaluslabs/fs-bench
# BENCH_WORKSPACE=/home/user
# BENCH_SKIP_NPM=0
# BENCH_SKIP_GIT=0
# BENCH_SKIP_TAR=0
# BENCH_SKIP_FIO=0
# BENCH_CONCURRENCY=4
